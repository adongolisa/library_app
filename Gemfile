# Gemfile

 source 'https://rubygems.org'
 git_source(:github) { |repo| "https://github.com/#{repo}.git" }

 ruby '3.2.2' # Specify your Ruby version here

 # Bundle edge Rails instead: gem "rails", github: "rails/rails", branch: "main"
 gem 'rails', '~>8.0.2'

 # Usesqlite3 database
 gem 'sqlite3', '~> 2.1'

 # Use Puma as the app server
 gem 'puma', '~> 6.0'

 # Use SCSS for stylesheets
 gem 'sass-rails', '>= 6'

 # Use JavaScript with ES6 syntax
 gem 'jsbundling-rails'

 # Use Turbolinks to make navigation faster
 gem 'turbolinks', '~> 5'

 # Use Hotwire for modern, fast front-end interactions
 gem 'hotwire-rails'

 # Use Bootstrap for styling
 gem 'bootstrap', '~> 5.3'
 gem 'bootsnap', '>= 1.4.4'
 gem 'sassc-rails', '>= 2.1.0'

 # Use Devise for authentication (optional, not needed for this project)
# gem 'devise'

 # Use Simple Form for better form handling (optional)
 # gem 'simple_form'

 # Use RuboCop for linting and style enforcement
 gem 'rubocop', '~> 1.56', require: false

 # Use RSpec for testing (optional, if you prefer RSpec over MiniTest)
 # gem 'rspec-rails', '~> 6.0'

 # Use Factory Bot for test data factories (optional, if using RSpec)
 # gem 'factory_bot_rails'

 # Use Faker for generating fake data (optional, for testing)
 # gem 'faker'

 # Use Debug for debugging
 gem 'debug', platforms: %i[mri mingw x64_mingw]

 # Use Dotenv for environment variables (optional)
 gem 'dotenv-rails', groups: [:development, :test]

 group :development, :test do
   # Use RSpec for testing (optional, if you prefer RSpec over MiniTest)
     # gem 'rspec-rails', '~> 6.0'

       # Use Factory Bot for test data factories (optional, if using RSpec)
         # gem 'factory_bot_rails'

           # Use Faker for generating fake data (optional, for testing)
             # gem 'faker'

               # Use Byebug for debugging
                 gem 'byebug', platforms: %i[mri mingw x64_mingw]
                 end

                 group :development do
                   # Use Better Errors for better error pages
                     gem 'better_errors'

                       # Use Binding of Caller for interactive debugging
                         gem 'binding_of_caller'

                           # Use Rails ERD for generating entity-relationship diagrams
                             gem 'rails-erd'

                               # Use Annotate for annotating models with schema information
                                 gem 'annotate'
                                 end

                                 group :test do
                                   # Use Capybara for integration testing
                                     gem 'capybara'

                                       # Use Webdrivers for browser testing
                                         gem 'webdrivers'

                                           # Use Shoulda Matchers for additional test matchers
                                             gem 'shoulda-matchers', '~> 6.0'
                                             end

                                             # Windows does not include zoneinfo files, so bundle the tzinfo-data gem
                                             gem 'tzinfo-data', platforms: %i[mingw mswin x64_mingw jruby]

gem "importmap-rails", "~> 2.1"
