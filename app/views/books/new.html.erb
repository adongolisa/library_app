<!-- app/views/books/new.html.erb -->

<h1>New Book</h1>

<%= form_with model: @book, local: true do |form| %>
    <div class="form-group">
          <%= form.label :title %>
              <%= form.text_field :title, class: 'form-control' %>
                </div>

                  <div class="form-group">
                        <%= form.label :author %>
                            <%= form.text_field :author, class: 'form-control' %>
                              </div>

                                <div class="form-group">
                                      <%= form.label :published_year %>
                                          <%= form.number_field :published_year, class: 'form-control' %>
                                            </div>

                                              <div class="form-group">
                                                    <%= form.label :status %>
                                                        <%= form.select :status, ['available', 'borrowed'], {}, class: 'form-control' %>
                                                          </div>

                                                            <%= form.submit 'Create Book', class: 'btn btn-primary' %>
                                                              <%= link_to 'Cancel', books_path, class: 'btn btn-secondary' %>
                                                            <% end %><!-- app/views/books/new.html.erb -->

                                                            
